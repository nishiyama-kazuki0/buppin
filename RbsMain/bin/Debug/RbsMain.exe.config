		<!--HULFTフォルダパス-->
		<add key="集信フォルダ" value="C:\RBSIF\HULFT\Recv\"/>
		<add key="配信フォルダ" value="C:\RBSIF\HULFT\Send\"/>
		<add key="保存フォルダ_RBSD010" value="C:\RBSIF\HULFT\Backup\正梱投入指示\"/>
		<add key="保存フォルダ_RBSD020" value="C:\RBSIF\HULFT\Backup\端数投入指示\"/>
		<add key="保存フォルダ_RBSU010" value="C:\RBSIF\HULFT\Backup\端数在庫実績\"/>
		<add key="保存フォルダ_RBSU020" value="C:\RBSIF\HULFT\Backup\投入実績\"/>
		<add key="保存フォルダ_RBSU030" value="C:\RBSIF\HULFT\Backup\投入NG実績\"/>
		<!--HULFTファイルID-->
		<add key="HULFTID_正梱投入指示" value="RBSD010" />
		<add key="HULFTID_端数投入指示" value="RBSD020" />
		<add key="HULFTID_端数在庫実績" value="RBSU010" />
		<add key="HULFTID_投入実績" value="RBSU020" />
		<add key="HULFTID_投入NG実績" value="RBSU030" />
