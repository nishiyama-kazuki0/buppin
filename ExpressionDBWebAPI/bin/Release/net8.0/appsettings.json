        "DefaultConnection": "Data Source=localhost\\SQLEXPRESS;Database=MHM-WMS-DB;TrustServerCertificate=True;Persist Security Info=True;User ID=sa;Password=sa;", //newtcremoteにする時は変更「192.168.140.27」
        "ReceiveUrl": "http://localhost:5001;" //newtcremoteにする時は変更「192.168.140.27」
    },
  "AISettings": {
    "AIEndPoint": "http://localhost:5000",
    "APIKey": "AIKey",
    "DeploymentID": "DeploymentID",
    "LimitTokenCount": 0
  },
    "PrintOutputSetting": {
        "IsPdfOutputOnly": true,
        "SavePdfFolderPath": "ダウンロード",
        "ToPrinterExePath": "", //印刷用EXEパス。使用したくない場合は存在しないパスを指定
        "ChankItemCount": 80,
        "ChankPageCount": 10, //未使用
        "PrintProcInterval": 500, //ms
        "PrintProcTimeout": 100000 //ms
    },
  "AllowedHosts": "*",
  //"Kestrel": {
  //  "EndPoints": {
  //    "HttpsInlineCertFile": {
  //      "Url": "https://192.168.1.161:5006", //KestrelServerのエンドポイントを指定（サーバーと競合しないポートを指定すること）
  //      "Certificate": {
  //        "Path": "C:\\ExpressionDB.pfx", //証明書を設定
  //        "Password": "0res@m@", //証明書のパスを設定
  //        "AllowInvalid": "true"
  //      }
  //    }
  //  }
  //},
  "Serilog": {
		"Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Async", "Serilog.Sinks.Console", "Serilog.Expressions" ],
    "MinimumLevel": {
      //最小ログレベル（Verbose、Debug、Information、Warning、Error、Fatal）
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning", // ASP.NET Core など Microsoft系のログは Warning 以上
        "ExpressionDBWebAPI": "Debug",
        "Program": "Information"
      }
    },
    "Enrich": [
      //拡張
      "WithThreadId", //スレッドID
      "WithThreadName", //スレッド名
      "WithMachineName", //マシン名
      "WithEnvironmentUserName", //ユーザー名
      "WithProcessId", //プロセスID
      "WithProcessName", //プロセス名
      "WithAssemblyName", //アセンブリ名
      "WithAssemblyVersion", //アセンブリバージョン
      "WithMemoryUsage", //メモリ使用量
      "WithExceptionDetails" //例外の詳細情報
    ],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                //最小ログレベル（Verbose、Debug、Information、Warning、Error、Fatal）
                "restrictedToMinimumLevel": "Verbose",
                //ファイルパス
								"path": "../Logs/WebAPILog_.log",
                //フォーマット
                "outputTemplate": "{Timestamp:HH:mm:ss.fff} | {Level:u4} | {ThreadId:00}:{ThreadName} | {ProcessId:00}:{ProcessName} | {Message:j} | {SourceContext} | {MethodName} | {LineNumber} L | {AssemblyName} | {AssemblyVersion} | {MachineName} | {EnvironmentUserName} | {MemoryUsage} B{NewLine}{Exception}",
                //日付ロール設定（Infinite:OFF、Minute:分毎、Hour:時間毎、Day:日毎、Month:月毎、Year:年毎）
                "rollingInterval": "Day",
                //ファイルサイズロール設定（false:OFF、true:ON）
                "rollOnFileSizeLimit": true,
                //ファイルサイズ(byte)制限（null:制限なし、単位byteで設定）
                "fileSizeLimitBytes": 1048576,
                //保持ファイル数（null:制限なし、ファイル数を設定）
                "retainedFileCountLimit": 10,
                //書き込みをバッファリングする（false:OFF、true:ON）
                "buffered": true
              }
            },
            {
              //Debug出力
              "Name": "Debug",
              //パラメータ
              "Args": {
                //最小ログレベル（Verbose、Debug、Information、Warning、Error、Fatal）
                "restrictedToMinimumLevel": "Verbose",
                //フォーマット
                "outputTemplate": "{Timestamp:HH:mm:ss.fff} | {Level:u4} | {ThreadId:00}:{ThreadName} | {ProcessId:00}:{ProcessName} | {Message:j} | {SourceContext} | {MethodName} | {LineNumber} L | {AssemblyName} | {AssemblyVersion} | {MachineName} | {EnvironmentUserName} | {MemoryUsage} B{NewLine}{Exception}"
              }
            },
            {
              //Console出力
              "Name": "Console",
              //パラメータ
              "Args": {
                //最小ログレベル（Verbose、Debug、Information、Warning、Error、Fatal）
                "restrictedToMinimumLevel": "Debug",
                //書き込みをバッファリングする（false:OFF、true:ON）
                "buffered": true
              }
            }
          ]
        }
			},
			{
				"Name": "Logger",
				"Args": {
					"configureLogger": {
						"Filter": [
							{
								"Name": "ByIncludingOnly",
								"Args": {
									"expression": "StartsWith(@m, 'SQL:')"
								}
							}
						],
						"WriteTo": [
							{
								"Name": "Async",
								"Args": {
									"configure": [
										{
											"Name": "File",
											"Args": {
												//最小ログレベル（Verbose、Debug、Information、Warning、Error、Fatal）
												//"restrictedToMinimumLevel": "Verbose",
												//ファイルパス
												"path": "../Logs/WebAPILog_SQL_.log",
												//フォーマット
												"outputTemplate": "{Timestamp:HH:mm:ss.fff} | {Level:u4} | {ThreadId:00}:{ThreadName} | {ProcessId:00}:{ProcessName} | {Message:j} | {SourceContext} | {MethodName} | {LineNumber} L | {AssemblyName} | {AssemblyVersion} | {MachineName} | {EnvironmentUserName} | {MemoryUsage} B{NewLine}{Exception}",
												//日付ロール設定（Infinite:OFF、Minute:分毎、Hour:時間毎、Day:日毎、Month:月毎、Year:年毎）
												"rollingInterval": "Day",
												//ファイルサイズロール設定（false:OFF、true:ON）
												"rollOnFileSizeLimit": true,
												//ファイルサイズ(byte)制限（null:制限なし、単位byteで設定）
												"fileSizeLimitBytes": 1048576,
												//保持ファイル数（null:制限なし、ファイル数を設定）
												"retainedFileCountLimit": 10,
												//書き込みをバッファリングする（false:OFF、true:ON）
												"buffered": true
											}
										}
									]
								}
							}
						]
					}
				}
      }
    ]
  }
}
