                                        </div>
                                    }
                                }
                                else
                                {
                                    <RadzenText Text="@strTitle" TextStyle="TextStyle.Subtitle2" style=@($"font-size:{DataGridColumnFontSize};font-weight:{DataGridCellFontWeight};") />
                                }
                            </HeaderTemplate>
                            <Template>
                                @if (IsHandyGridSelect)
                                {
                                    <div tabindex="0" id="FocusUpper_@(Data.IndexOf(context))"></div>
                                }
                                @{
                                    List<int> lstBaraRow = new List<int>();
                                    strTitle = strTitle.Replace("\\n", "\n");
                                    if (strTitle.Contains("\n"))
                                    {
                                        string[] lines = strTitle.Split("\n");
                                        @for (int i = 0; lines.Length > i; i++)
                                        {
                                            string line = lines[i];
                                            bool bBara = line.Contains(SharedConst.STR_HT_BARA_COLOR_CONTAINS);
                                            if (bBara)
                                            {
                                                lstBaraRow.Add(i);
                                            }
                                        }
                                    }
                                    else
                                    {
                                        bool bBara = strTitle.Contains(SharedConst.STR_HT_BARA_COLOR_CONTAINS);
                                        if (bBara)
                                        {
                                            lstBaraRow.Add(0);
                                        }
                                    }

                                    string strValue = string.Empty;
                                    if (context.ContainsKey(col.Property))
                                    {
                                        strValue = context[col.Property] is null ? "" : context[col.Property].ToString();
                                    }
                                    strValue = strValue.Replace("\\n", "\n");

                                    // ゼロサプレス
                                    if (col.FormatString == SharedConst.FORMAT_ZERO_SUPPRESS)
                                    {
                                        strValue = strValue.TrimStart('0');
                                    }
                                }
                                @if (strValue.Contains("\n"))
                                {
                                    string[] lines = strValue.Split("\n");
                                    @for (int i = 0; lines.Length > i; i++)
                                    {
                                        string line = lines[i];
                                        bool bBara = lstBaraRow.Contains(i);
                                        <div>
                                            <RadzenText Text="@(bBara && line == "0" ? "" : line)" TextStyle="TextStyle.Body2" style=@($"font-size:{DataGridCellFontSize};font-weight:{DataGridCellFontWeight};{(bBara ? $"color:{BaraColor}" : "")}") />
                                        </div>
                                    }
                                }
                                else
                                {
                                    bool bBara = lstBaraRow.Contains(0);
                                    <RadzenText Text="@(bBara && strValue == "0" ? "" : strValue)" TextStyle="TextStyle.Body2" style=@($"font-size:{DataGridCellFontSize};font-weight:{DataGridCellFontWeight};{(bBara ? $"color:{BaraColor}" : "")}") />
                                }
                                @if (IsHandyGridSelect)
                                {
                                    <div tabindex="0" id="FocusLower_@(Data.IndexOf(context))"></div>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    }
                </Columns>
            </RadzenDataGrid>
        }
    </div>
</div>

