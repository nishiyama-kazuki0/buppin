                            {
                                <RadzenSplitButton Icon="get_app" Text="Export" Click="@ExportClick" Variant="Variant.Flat" Shade="Shade.Lighter">
                                    @foreach (SeparatedFileInfo info in SharedConst.SeparatedFileInfos)
                                    {
                                        <RadzenSplitButtonItem Text="@info.Name" Value="@info.Extension" />
                                    }
                                </RadzenSplitButton>
                            }
                            @if (VisibleSettings)
                            {
                                <span style="display: flex; flex-wrap: nowrap;justify-content: center; align-items: center;">
                                    <RadzenText TextStyle="TextStyle.Body2" TagName="TagName.Span"Style="margin-bottom:0px;">表示密度:</RadzenText>
                                    <RadzenSelectBar @bind-Value="@Density" TextProperty="Text" ValueProperty="Value"
                                                     Data="@(Enum.GetValues(typeof(Density)).Cast<Density>().Select(t => new { Text = $"{t}", Value = t }))" Size="ButtonSize.Small" />
                                </span>
                            }
                            @if (AllowPageing)
                            {
                                <span style="display: flex; flex-wrap: nowrap;justify-content: center; align-items: center;">
                                    <RadzenText TextStyle="TextStyle.Body2" TagName="TagName.Span" Style="margin-bottom:0px;">表示行数:</RadzenText>
                                    <RadzenNumeric Min="0" Max="1000" @bind-Value=@PageSize style="width:100px;" />
                                </span>
                            }
                            @if (!string.IsNullOrEmpty(HeaderTextTitle) || !string.IsNullOrEmpty(HeaderTextValue))
                            {
                                <span style="display: flex; flex-wrap: nowrap;justify-content: center; align-items: center;">
                                    <RadzenText TextStyle="TextStyle.Body2" TagName="TagName.Span" Style=@($"font-size:{DataGridHeaderFontSize};margin-bottom:0px;")>@HeaderTextTitle</RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body2" TagName="TagName.Span" Style=@($"font-size:{DataGridHeaderFontSize};margin-bottom:0px;")>@HeaderTextValue</RadzenText>
                                </span>
                            }
                        </RadzenRow>
                    </HeaderTemplate>
                    <Columns>
                        @*チェックボックスカラム*@
                        @if (SelectionMode == DataGridSelectionMode.Multiple)
                        {
                            <RadzenDataGridColumn TItem="IDictionary<string, object>" Title="check" Width="40px" Sortable="false" Filterable="false" Reorderable="false" Resizable="false">
                                <HeaderTemplate>
                                    <RadzenCheckBox TriState="false" TValue="bool" Value="@(Data.Any(i => SelectedData != null && SelectedData.Contains(i)))"
                                                    Change="@(args => OnValueChanged(args ? Data.ToList() : null))" />
                                </HeaderTemplate>
                                <Template Context="data">
                                    <RadzenCheckBox TriState="false" Value="@(SelectedData != null && SelectedData.Contains(data))"
                                                    TValue="bool" Change="@ChangeSelectCheckClick" />
                                </Template>
                            </RadzenDataGridColumn>
                        }
                        else
                        {

                        }

                        @*データカラム*@
                        @foreach (var col in this.Columns)
                        {
                            string strTitle = string.IsNullOrEmpty(col.Title) ? col.Property : col.Title;
                            <RadzenDataGridColumn TItem="IDictionary<string, object>" Width="@GetColumnWidthExpression(col.Width)"
