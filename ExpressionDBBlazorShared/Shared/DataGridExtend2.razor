                                                  Sortable="@col.Sortable" Filterable="@col.Filterable" Reorderable="@col.Reorderable" Resizable="@col.Resizable"
                                                  FormatString="@col.FormatString" Pickable="(col.Width != 0)" Visible="(col.Width != 0 && !col.UserSetHidden)">
                                @* col.key内に改行コードが含まれていれば、改行してヘッダー名を表示する*@
