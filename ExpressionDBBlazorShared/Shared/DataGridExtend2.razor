
<style>
    /* 
    ベースとなるCSSはRadzenの「～-base.css」
    */

    /* セル背景色を設定する */
    .rz-grid-table-striped tbody tr.rz-data-row td.rz-set-background-color {
        background-color: var(--bg-color);
    }

    /* selectableはRowのhoverで対象セル以外は色が変わらないようにする */
    .rz-grid-table-striped tbody tr.rz-data-row:hover:not(.rz-state-highlight):nth-child(even) > td.rz-selectable-cell:not(:hover):not(.rz-selected-cell) {
        background-color: var(--rz-grid-stripe-background-color);
    }

    .rz-grid-table-striped tbody tr.rz-data-row:hover:not(.rz-state-highlight):nth-child(odd) > td.rz-selectable-cell:not(:hover):not(.rz-selected-cell) {
        background-color: var(--rz-grid-stripe-odd-background-color);
    }

    .rz-selectable tbody tr.rz-data-row:hover:not(.rz-state-highlight) > td.rz-selectable-cell.rz-set-background-color:not(:hover):not(.rz-selected-cell) {
        background-color: var(--bg-color);
    }
    
    /* 選択可能セルはホバー時に背景色を変更 */
    .rz-selectable tbody tr.rz-data-row td.rz-selectable-cell:hover:not(.rz-selected-cell) {
        background-color: var(--rz-grid-hover-background-color);
    }

    /* 選択状態セルの背景色を変更 */
    .rz-selectable tbody tr.rz-data-row td.rz-selectable-cell.rz-selected-cell {
        background-color: var(--rz-grid-selected-background-color);
    }

    /* unselectableはhoverでも色が変わらないようにする */
    .rz-grid-table-striped tbody tr.rz-data-row:hover:not(.rz-state-highlight):nth-child(even) > td.rz-unselectable-cell {
        background-color: var(--rz-grid-stripe-background-color);
    }

    .rz-grid-table-striped tbody tr.rz-data-row:hover:not(.rz-state-highlight):nth-child(odd) > td.rz-unselectable-cell {
        background-color: var(--rz-grid-stripe-odd-background-color);
    }

    .rz-selectable tbody tr.rz-data-row:hover:not(.rz-state-highlight) > td.rz-unselectable-cell.rz-set-background-color {
        background-color: var(--bg-color);
    }
</style>

<div class="row" style="margin-bottom: 0rem">
    <div class="col-12 col-md-6">
        @*上段左半分*@
    </div>
    <div class="col-12 col-md-6 justify-content-start justify-content-md-end" style="display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem">
        @*上段右半分*@
        @*@if (AllowDataExport){

        }*@
    </div>
</div>
<div class="row">
    <div class="col-md-12">
        @if (!IsHandy)
        {
            @*PC用*@
            @if (Columns.Where(_ => _.SummaryType != 0).Count() > 0)
            {
                @*FooterTemplateあり*@
                <RadzenDataGrid @ref="@MainGrid"
                    Data="@Data"
                    ColumnWidth="200px"
                    AllowFiltering="@AllowFiltering"
                    FilterMode="@FilterMode"
                    AllowColumnReorder="@AllowColumnReorder"
                    AllowColumnResize="@AllowColumnResize"
                    AllowPaging="@AllowPageing"
                    AllowSorting="@AllowSorting"
                    AllowMultiColumnSorting="@AllowMultiColumnSorting"
                    AllowVirtualization="@AllowVirtualization"
                    ShowMultiColumnSortingIndex="@AllowMultiColumnSorting"
                    ShowPagingSummary="@ShowPagingSummary"
                    PagerHorizontalAlign="@PagerHorizontalAlign"
                    Count=Data.Count()
                    TItem="IDictionary<string, object>"
                    SelectionMode="@SelectionMode"
                    Value="@SelectedData"
                    AllowColumnPicking="@AllowColumnPicking"
                    Density="@Density"
                    PageSize="@PageSize"
                    @attributes="AttributesStringText"
                    EditMode="DataGridEditMode.Single"
                    CellRender="@OnCellRender"
                    ValueChanged="@OnValueChanged"
                    CellClick="@OnCellClick"
                    Style=@(string.IsNullOrWhiteSpace(GridHeight)? string.Empty:$"height:{GridHeight}" )>
