@inherits CompBase
@using ExpressionDBBlazorShared.Validator;
@using ExpressionDBBlazorShared.Services;
<style>
    .@(GetType().Name) .rz-spinner-input {
        font-size: @($"{CompFontSize}");
        font-weight: @($"{CompFontWeight}");
    }
</style>
<RadzenNumeric 
    Disabled="@Disabled" 
    class="@Class" 
    style="@Style" 
    TValue="decimal" 
    @bind-Value="@_inputValue" 
    Format="@Format" 
    Step="@Step" 
    Min="@Min" 
    Max="@Max" />
@if (Required)
{
    <RequiredValidator For="() => InputValue" ItemName=@Title />
}
@if (Min is not null || Max is not null)
{
    <NumericRangeValidator For="() => InputValue" ItemName=@Title Min=@Min Max=@Max FormatMinMax="@FormatMinMax" />
}
