<UserControl x:Class="ExpressionDBCycleProcessApp.Views.UcSequenceActions"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExpressionDBCycleProcessApp.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             >
    <Grid
        
        >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー部 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            
            
            <StackPanel
                Orientation="Horizontal">

                <!-- 表示階層 -->
                <Label
                    Content="表示階層" />
                <ComboBox
                    ItemsSource="{Binding Levels}"
                    SelectedItem="{Binding Level.Value}"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Right"
                    />

                <Label Content="クラス名" />
                <TextBox
                    Text="{Binding ClassName.Value}"
                    MinWidth="100"/>

                <!-- 更新ボタン -->
                <Button 
                    Content="更新" 
                    Command="{Binding CommandRefresh}"
                    HorizontalAlignment="Left"/>

                <!-- 件数 -->
                <TextBlock
                    VerticalAlignment="Center"
                    Text="{Binding Count1.Value}" />
                <TextBlock
                    VerticalAlignment="Center"
                    Text="件" />
            </StackPanel>
            <Button 
                Grid.Column="1"
                Content="TSV出力"
                Command="{Binding CommandCsv}" 
                HorizontalAlignment="Right"
                />
        </Grid>

        <Grid
            Grid.Row="1"
            >
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="5" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!-- Splitter -->
            <GridSplitter
            Grid.Column="1"
            Width="5"
            Background="Gray"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ResizeBehavior="PreviousAndNext"
            ShowsPreview="True" />

            <!-- 一覧 -->
            <DataGrid
            ItemsSource="{Binding SequenceActions.Value}"
            SelectedItem ="{Binding SelectedSequenceAction.Value}"
            SelectionMode="Single"
            IsReadOnly="True"
            AutoGenerateColumns="False"
            >
                <!-- Ctrl + C のショートカットキーでコピーコマンドを実行 -->
                <DataGrid.InputBindings>
                    <KeyBinding Key="C" Modifiers="Control" Command="{Binding GridCellTextCopy.Command}" />
                </DataGrid.InputBindings>
                <i:Interaction.Behaviors>
                    <local:FocusedCellValueBehavior FocusedCellValue="{Binding GridCellTextCopy.FocusedCell.Value, Mode=TwoWay}" />
                </i:Interaction.Behaviors>
                <!-- 選択状態の色設定 -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Orange" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="Navy" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Mark.Value}" Value="●">
                                <Setter Property="Background" Value="LightGreen"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Green" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                

                <DataGrid.Columns>
                    <DataGridTextColumn Header="実行中" Binding="{Binding Mark.Value}" Width="Auto" >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="実行日時" Binding="{Binding SequenceExecuteDateTime, StringFormat=yyyy/MM/dd HH:mm:ss.fff}" Width="140" />
                    <DataGridTextColumn Header="CurrentStepName" Binding="{Binding CurrentStepName}" Width="160" />
                    <DataGridTextColumn Header="STEP" Binding="{Binding CurrentStepString}" Width="Auto" />
                    <DataGridTextColumn Header="SeqIDSummary" Binding="{Binding SeqIDSummary}" Width="Auto" />
                    <DataGridTextColumn Header="SeqID" Binding="{Binding SeqID}" Width="Auto" />
                    <DataGridTextColumn Header="ClassSummary" Binding="{Binding ClassSummary}" Width="Auto" />
                    <DataGridTextColumn Header="Class名" Binding="{Binding ClassName}" Width="Auto" />
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button
                                    Content="開く"
                                    Command="{Binding CommandOpenSourceFile}" 
                                    />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="InstanceId" Binding="{Binding InstanceId}" Width="70" />
                    <DataGridTextColumn Header="PID" Binding="{Binding PID}" Width="60" />
                    <DataGridTextColumn Header="階層" Binding="{Binding Level}" Width="50" />
                    <DataGridTextColumn Header="Parent" Binding="{Binding Parent.ClassName}" Width="Auto" />
                    <DataGridTextColumn Header="排他実行" Binding="{Binding NeedExclusive}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
            
            <!-- 選択されたSequenceAction -->
            <ScrollViewer
                Grid.Column="2"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                >
                <StackPanel
                    Orientation="Vertical">
                    <local:UcSequenceAction
                        DataContext="{Binding SelectedSequenceAction.Value}" 
                        VerticalAlignment="Top"
                        />

                    <TextBlock
                        Text="↓SubSequences"
                        Foreground="Red" />
                    <!-- ツリー表示部 -->
                    <TreeView
                        Grid.Row="1"
                        ItemsSource="{Binding SelectedSequenceAction.Value.Children}"
            >
                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" 
                            Value="{Binding IsExpanded.Value, Mode=TwoWay}" />
                                <Setter Property="IsSelected" 
                            Value="{Binding IsSelected.Value, Mode=TwoWay}" />
                            </Style>
                        </TreeView.Resources>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate
                                ItemsSource="{Binding Children}"
                    >
                                <local:UcSequenceAction DataContext="{Binding}"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
