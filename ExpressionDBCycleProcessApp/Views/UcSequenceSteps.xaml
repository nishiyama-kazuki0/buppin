<UserControl x:Class="ExpressionDBCycleProcessApp.Views.UcSequenceSteps"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ExpressionDBCycleProcessApp.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー部 -->
        <StackPanel
            Orientation="Horizontal">
            <Button 
                Content="更新" 
                Command="{Binding CommandRefresh}"
                HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding Count.Value}" />
            <TextBlock Text="件" />
        </StackPanel>

        <Grid
           Grid.Row="1"
           >
            <!-- 一覧 -->
            <DataGrid
                ItemsSource="{Binding SequenceSteps}"
                SelectionMode="Single"
                IsReadOnly="True"
               >
                <!-- Ctrl + C のショートカットキーでコピーコマンドを実行 -->
                <DataGrid.InputBindings>
                    <KeyBinding Key="C" Modifiers="Control" Command="{Binding GridCellTextCopy.Command}" />
                </DataGrid.InputBindings>
                <i:Interaction.Behaviors>
                    <local:FocusedCellValueBehavior FocusedCellValue="{Binding GridCellTextCopy.FocusedCell.Value, Mode=TwoWay}" />
                </i:Interaction.Behaviors>

                <!-- 選択状態の色設定 -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Orange" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="Navy" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
