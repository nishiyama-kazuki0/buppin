<UserControl x:Class="ExpressionDBCycleProcessApp.Views.UcSequenceActions2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExpressionDBCycleProcessApp.Views"
             mc:Ignorable="d" 
             >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- 左半分 -->
        <Grid>
            <Grid.RowDefinitions>
                <!--ヘッダ部-->
                <RowDefinition Height="Auto"/>
                <!--一覧部-->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ヘッダ部 -->
            <StackPanel
                Orientation="Horizontal">

                <!-- 抽出条件群 -->
                <StackPanel
                    Orientation="Vertical">

                    <!-- IsNotIdleOnly -->
                    <CheckBox
                    Content="待機以外を含む行のみ表示" 
                    IsChecked="{Binding IsNotIdleOnly.Value}"/>

                    <!-- 検索文字列 -->
                    <StackPanel
                    Orientation="Horizontal">
                        <Label 
                        Content="検索文字列" />
                        <TextBox
                        Text="{Binding SearchWords.Value,Mode=TwoWay}"
                        MinWidth="100" />
                    </StackPanel>
                </StackPanel>

                <!-- 表示更新 -->
                <Button
                    Content="表示更新"
                    Command="{Binding CommandRefresh}"
                    />
                <StackPanel
                Orientation="Horizontal">
                    <Label Content="SequenceStep名"/>
                    <ComboBox
                    ItemsSource="{Binding SequenceStepNameList}"
                    SelectedItem="{Binding SelectedSequenceStepName.Value}"
                    />
                </StackPanel>
            </StackPanel>

            <!-- SequensID毎の一覧 -->
            <Grid
            Grid.Row="1"
            >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 件数 -->
                <TextBlock
                Text="{Binding SequenceActions.Value.Count}" 
                HorizontalAlignment="Right"
                />

                <DataGrid
                Grid.Row="1"
                ItemsSource="{Binding SequenceActions.Value}"
                SelectedItem="{Binding SelectedSeqenceActions.Value}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Key" Binding="{Binding Key}" />
                        <DataGridTextColumn Header="SequenceIDSummary" Binding="{Binding Value.SequenceIDSummary}" />
                        <DataGridTextColumn Header="PID" Binding="{Binding Value.PID}" />
                        <DataGridTextColumn Header="件数" Binding="{Binding Value.Count}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Splitter -->
        <GridSplitter
            Grid.Column="1"
            Width="5"
            Background="Gray"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ResizeBehavior="PreviousAndNext"
            ShowsPreview="True" />
        <!-- 右半分 -->
        <Grid
            Grid.Column="2"
            >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <local:UcSequenceAction
                Grid.Row="0"
                DataContext="{Binding SelectedSequenceAction.Value}" />
            
            <!-- 選択したSequensIDの一覧 -->
            <Grid
                Grid.Row="1"
                >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 件数表示 -->
                <TextBlock
                    Text="{Binding Count2.Value}" 
                    HorizontalAlignment="Right"
                    />

                <DataGrid
                    Grid.Row="1"
                    ItemsSource="{Binding SelectedSeqenceActions.Value.Value}"
                    SelectedItem="{Binding SelectedSequenceAction.Value}"
                    IsReadOnly="True"
                    HorizontalScrollBarVisibility="Visible"
                    VerticalScrollBarVisibility="Visible"
                    AutoGenerateColumns="False"
                    >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="実行日時" Binding="{Binding SequenceExecuteDateTime}" />
                        <DataGridTextColumn Header="CurrentStepString" Binding="{Binding CurrentStepString}" Width="120" />
                        <DataGridTextColumn Header="ClassName" Binding="{Binding ClassName}"/>
                        <DataGridTextColumn Header="CurrentStepName" Binding="{Binding CurrentStepName}" Width="Auto" />
                        <DataGridTextColumn Header="ClassSummary" Binding="{Binding ClassSummary}" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
