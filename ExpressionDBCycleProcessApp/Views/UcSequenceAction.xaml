<UserControl x:Class="ExpressionDBCycleProcessApp.Views.UcSequenceAction"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:vm="clr-namespace:ExpressionDBCycleProcessApp.ViewModels"            
             xmlns:local="clr-namespace:ExpressionDBCycleProcessApp.Views"
             >
    <UserControl.Resources>
        <!-- 再帰的な表示 -->
        <HierarchicalDataTemplate
            DataType="{x:Type vm:PropertyViewModel}"
            ItemsSource="{Binding Children}">
            <!-- 展開/折りたたみ用のヘッダー -->
            <StackPanel
                Orientation="Horizontal"
                Margin="4">
                <TextBox
                    Text="{Binding Path= Name,Mode=OneWay}"
                    MinWidth="100"
                    FontWeight="Bold"
                    BorderBrush="Transparent" 
                    IsReadOnly="True" />
                <TextBox
                    Style="{StaticResource LabelLikeStyle}" 
                    Text="{Binding Path=TypeName,Mode=OneWay}" 
                         />
                <TextBox
                    Style="{StaticResource LabelLikeStyle}" 
                    Text="=" 
                         />
                <TextBox
                    Style="{StaticResource LabelLikeStyle}" 
                    Text="{Binding Path=Value,Mode=OneWay}" 
                         />

            </StackPanel>
        </HierarchicalDataTemplate>
        <DataTemplate
            DataType="{x:Type vm:SequenceStepViewModel}">
            <local:UcSequenceStep DataContext="{Binding}" />
        </DataTemplate>
    </UserControl.Resources>   
    <Border
        BorderBrush="Black"
        BorderThickness="1"
        Margin="1">
        <StackPanel
            Orientation="Vertical">

            <StackPanel
            Orientation="Horizontal"
            >
                <Button
                    Content="表示更新" 
                    Command="{Binding CommandRefresh}"/>
                <!-- 子の件数 -->
                <StackPanel
                Orientation="Vertical"
                >

                    <Label 
                Content="子" />
                    <TextBlock Text="{Binding Children.Count}" />
                    <TextBlock Text="{Binding AllChildren}" />
                </StackPanel>

                <!-- SeqID -->
                <StackPanel
                    Orientation="Vertical"
                    Background="LightCyan"
                    Visibility="{Binding DetailVisibility.Value,Mode=TwoWay}"
                    >

                    <Label 
                    Content="SeqID/SeqIDSummary" />
                    <TextBox
                        Style="{StaticResource LabelLikeStyle}" 
                        Text="{Binding SeqIDSummary,Mode=OneWay}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox
                            Style="{StaticResource LabelLikeStyle}" 
                            Text="{Binding SeqID,Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
                
                <!-- ClassSummary/クラス名 -->
                <StackPanel
                    Orientation="Vertical"
                    Background="LightPink"
                    >
                    <Label  Content="ClassSummary/クラス名" />
                    <TextBox
                        Style="{StaticResource LabelLikeStyle}" 
                        Text="{Binding ClassSummary,Mode=OneWay}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox
                        Style="{StaticResource LabelLikeStyle}" 
                            Text="{Binding ClassName,Mode=OneWay}"
                            />
                        <Button
                        Content="開く"
                        Command="{Binding CommandOpenSourceFile}" />
                    </StackPanel>
                </StackPanel>


                <!-- PID -->
                <StackPanel
                    Orientation="Vertical"
                    Background="LightCyan"
                    Visibility="{Binding DetailVisibility.Value,Mode=TwoWay}"
                    >

                    <Label 
                    Content="PID" />
                    <TextBlock Text="{Binding PID}" />
                </StackPanel>

                <!-- NeedExclusive -->
                <StackPanel
                    Orientation="Vertical"
                    Background="DarkGray"
                    Visibility="{Binding DetailVisibility.Value,Mode=TwoWay}"
                    >
                    <Label Content="NeedExclusive" />
                    <TextBlock Text="{Binding NeedExclusive}" />
                </StackPanel>

            </StackPanel>
            
            <!-- プロパティ表示 -->
            <GroupBox
                Header="プロパティ">
                <Grid >
                    <ScrollViewer VerticalScrollBarVisibility="Auto" >
                        <TreeView
                            ItemsSource="{Binding RootProperties}" 
                            >
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded"
                                            Value="{Binding IsExpanded.Value, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </GroupBox>

            <!-- ステップ関連 -->
            <GroupBox
                Header="ステップ情報"
                Visibility="{Binding DetailVisibility.Value,Mode=TwoWay}"
                >

                <StackPanel
                    Orientation="Horizontal"
                    >
                    <!-- CurrentStepName -->
                    <StackPanel
                        Orientation="Vertical"
                        Background="LightGreen"
                >
                        <Label Content="CurrentStepName" />
                        <TextBlock Text="{Binding CurrentStepName}" />
                    </StackPanel>

                    <!-- State -->
                    <StackPanel
                        Orientation="Vertical"
                        Background="LightGreen"
                >
                        <Label Content="State" />
                        <TextBlock Text="{Binding State}" />
                    </StackPanel>

                    <!-- 詳細 -->
                    <Grid>
                        <StackPanel
                            Orientation="Horizontal">
                            <DataGrid
                                ItemsSource="{Binding Steps}"
                                SelectedItem="{Binding SelectedStep.Value,Mode=TwoWay}"
                                AutoGenerateColumns="False"
                                SelectionMode="Single"
                                SelectionUnit="FullRow"
                                >
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Foreground" Value="Black"/>
                                                <Setter Property="Background" Value="LightGreen"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <!-- セルスタイル -->
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="DataGridRow.IsSelected" Value="True">
                                                <Setter Property="Foreground" Value="Black"/>
                                                <Setter Property="Background" Value="LightGreen"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="FieldName" Binding="{Binding StepFieldName}" Width="Auto" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                                    <DataGridTextColumn Header="FieldSummary" Binding="{Binding FieldSummary}" />
                                </DataGrid.Columns>
                                    
                            </DataGrid>
                            <!--
                            <ListBox
                                ItemsSource="{Binding Steps}"
                                SelectedItem="{Binding SelectedStep.Value,Mode=TwoWay}"
                                >

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="5"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1"
                                                        Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="LightGreen"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            -->
                            <Button
                                Content="変更"
                                Command="{Binding CommandChange}"
                                />

                        </StackPanel>
                    </Grid>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Border>
</UserControl>
