<UserControl x:Class="ExpressionDBCycleProcessApp.Views.UcCommunicationArea"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:ExpressionDBCycleProcessApp.ViewModels"
             xmlns:local="clr-namespace:ExpressionDBCycleProcessApp.Views"
             >
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:CBitViewModel}">
            <local:UcCBit />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CDwordViewModel}">
            <local:UcCDword />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CWordViewModel}">
            <local:UcCWord />
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition/>
        </Grid.RowDefinitions>
        
       <!-- ヘッダ部 -->
        <StackPanel
            Orientation="Horizontal"
            Background="Yellow"
            >
            <!-- 絞り込み -->
            <StackPanel
                Orientation="Horizontal">
                <Label Content="デバイス名称" />
                <TextBox
                            MinWidth="200"
                            Text="{Binding DeviceName.Value}" />
            </StackPanel>
            <StackPanel
                Orientation="Horizontal">
                <Label Content="デバイス番号" />
                <TextBox
                            MinWidth="200"
                            Text="{Binding DeviceNo.Value}" />
            </StackPanel>
            <CheckBox
                Content="bit ONのみ"
                IsChecked="{Binding IsTrueOnly.Value}"
                VerticalAlignment="Center"
                />

            <Button 
            Content="表示" 
            Command="{Binding CommandRefresh}"
            />

            <Button 
            Content="デバイス値取得" 
            Command="{Binding CommandGetDeviceValues}"
            />
        </StackPanel>

        <Grid
            Grid.Row="1"
            >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="580"/>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="820" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <!-- Splitter 1 -->
            <GridSplitter
                Grid.Column="1"
                Width="5"
                Background="Gray"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ResizeBehavior="PreviousAndNext"
                ShowsPreview="True" />

            <!-- Splitter 2 -->
            <GridSplitter
                Grid.Column="3"
                Width="5"
                Background="DarkGray"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ResizeBehavior="PreviousAndNext"
                ShowsPreview="True" />
            
            <!-- 通信Area -->
            <DataGrid
                    ItemsSource="{Binding 通信Area}"
                    SelectedItem="{Binding Selected通信Area.Value}"
                    >

                <!-- Ctrl + C のショートカットキーでコピーコマンドを実行 -->
                <DataGrid.InputBindings>
                    <KeyBinding Key="C" Modifiers="Control" Command="{Binding GridCellTextCopy1.Command}" />
                </DataGrid.InputBindings>
                <i:Interaction.Behaviors>
                    <local:FocusedCellValueBehavior FocusedCellValue="{Binding GridCellTextCopy1.FocusedCell.Value, Mode=TwoWay}" />
                </i:Interaction.Behaviors>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Orange" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="Navy" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter Property="Background" Value="GreenYellow"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <!-- 選択したAreaのデバイス一覧 -->
            <Grid
                Grid.Column="2"
                >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
                    <TextBlock
                        Text="{Binding Selected通信Area.Value.FieldInfoList.Count}"
                        />
                    <TextBlock 
                        Text="件"
                        />
                </StackPanel>
                <DataGrid
                Grid.Row="1"
                Margin="2"
                ItemsSource="{Binding Selected通信Area.Value.FieldInfoList}"
                SelectedItem="{Binding SelectedFieldInfo.Value}"
                VerticalScrollBarVisibility="Visible"
                HorizontalScrollBarVisibility="Visible"
                SelectionMode="Extended"
                IsReadOnly="True"
                AutoGenerateColumns="False"
                >

                    <!-- Ctrl + C のショートカットキーでコピーコマンドを実行 -->
                    <DataGrid.InputBindings>
                        <KeyBinding Key="C" Modifiers="Control" Command="{Binding GridCellTextCopy2.Command}" />
                    </DataGrid.InputBindings>
                    <i:Interaction.Behaviors>
                        <local:FocusedCellValueBehavior FocusedCellValue="{Binding GridCellTextCopy2.FocusedCell.Value, Mode=TwoWay}" />
                    </i:Interaction.Behaviors>

                    <DataGrid.Columns>
                    <DataGridTextColumn IsReadOnly="True" Header="Name2" Binding="{Binding Name2}" Width="Auto" />
                    <DataGridTextColumn IsReadOnly="True" Header="Type" Binding="{Binding Type}" Width="Auto" />
                    <DataGridTextColumn IsReadOnly="True" Header="Address" Binding="{Binding DeviceName}" Width="Auto" />
                    <DataGridTextColumn IsReadOnly="True" Header="Name" Binding="{Binding Name}" Width="Auto" />
                    <DataGridTextColumn IsReadOnly="True" Header="Value" Binding="{Binding Value.Value}" Width="60" />
                    <DataGridTextColumn IsReadOnly="True" Header="Comment1" Binding="{Binding Comment1}" Width="120" />
                    <DataGridTextColumn IsReadOnly="True" Header="Comment2" Binding="{Binding Comment2}" Width="120" />
                    <DataGridTextColumn IsReadOnly="True" Header="Summary" Binding="{Binding Summary}" />
                </DataGrid.Columns>
                <!-- 選択状態の色設定 -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Orange" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="Navy" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Green" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
            </Grid>

            <!-- 選択したデバイス -->
            <ContentControl
                Grid.Column="4"
                Content="{Binding DeviceVm.Value}" />
        </Grid>
    </Grid>
</UserControl>
