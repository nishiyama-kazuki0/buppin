<UserControl
    x:Class="ExpressionDBCycleProcessApp.Views.UcSequenceStepHistories"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:ExpressionDBCycleProcessApp.Views"
    >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー部 -->
        <StackPanel
            Orientation="Horizontal">

            <StackPanel
                Orientation="Horizontal">
                <!-- InstanceId -->
                <Label
                Content="InstanceId" />
                <TextBox
                    Width="200"
                    Text="{Binding InstanceId.Value}" />
                <!-- クラス名 -->
                <Label
                Content="クラス名" />
                <TextBox
                    Width="200"
                    Text="{Binding TypeName.Value}" />
                <!-- ID -->
                <Label
                Content="ID" />
                <TextBox 
                    Width="200"
                    Text="{Binding ID.Value}" />

            </StackPanel>
            
            <Button 
                Content="更新" 
                Command="{Binding CommandRefresh}"
                HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding Count.Value}" />
            <TextBlock Text="件" />
        </StackPanel>

        <Grid
           Grid.Row="1"
           >
            <!-- 一覧 -->
            <DataGrid
                ItemsSource="{Binding Rows}"
                SelectionMode="Single"
                IsReadOnly="True"
                AutoGenerateColumns="False"
               >
                <!-- Ctrl + C のショートカットキーでコピーコマンドを実行 -->
                <DataGrid.InputBindings>
                    <KeyBinding Key="C" Modifiers="Control" Command="{Binding GridCellTextCopy.Command}" />
                </DataGrid.InputBindings>
                <i:Interaction.Behaviors>
                    <local:FocusedCellValueBehavior FocusedCellValue="{Binding GridCellTextCopy.FocusedCell.Value, Mode=TwoWay}" />
                </i:Interaction.Behaviors>

                <!-- 選択状態の色設定 -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Orange" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="Navy" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="日時" Binding="{Binding DateTime, StringFormat=HH:mm:ss.fff}" Width="100" />
                    <DataGridTextColumn Header="InstanceId" Binding="{Binding InstanceId}" />
                    <DataGridTextColumn Header="クラス名" Binding="{Binding Type}" />
                    <DataGridTextColumn Header="ID" Binding="{Binding ID}" />
                    <DataGridTextColumn Header="OldStep" Binding="{Binding OldStep}" />
                    <DataGridTextColumn Header="OldFieldName" Binding="{Binding OldFieldName}" />
                    <DataGridTextColumn Header="NewStep" Binding="{Binding NewStep}" />
                    <DataGridTextColumn Header="NewFieldName" Binding="{Binding NewFieldName}" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
