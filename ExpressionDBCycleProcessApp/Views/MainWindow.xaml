<Window x:Class="ExpressionDBCycleProcessApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dragDrop="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"        
        xmlns:local="clr-namespace:ExpressionDBCycleProcessApp.Views"
        xmlns:vm="clr-namespace:ExpressionDBCycleProcessApp.ViewModels"            
        Title="CycleProcess"
        Height="450" 
        Width="800"
        Background="{Binding MonitoredBgColor.Value}"
        >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー部1 -->
        <StackPanel>
            <CheckBox
                Content="監視中(未実装)"
                IsChecked="{Binding IsMonitored.Value}"
                />
        </StackPanel>
        
        <!-- タブ切り替え部 -->
        <TabControl
            Grid.Row="1"
            ItemsSource="{Binding TabItems}"
            SelectedItem="{Binding SelectedItem.Value}"
            dragDrop:DragDrop.IsDragSource="True"
            dragDrop:DragDrop.IsDropTarget="True"
            dragDrop:DragDrop.DropHandler="{Binding}"
            >
            <!-- ヘッダー部 -->
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <!-- コンテンツ部 -->
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <!-- Contentを型に基づいて切り替える -->
                    <ContentControl Content="{Binding Content}">
                        <ContentControl.ContentTemplateSelector>
                            <vm:TabContentTemplateSelector />
                        </ContentControl.ContentTemplateSelector>
                    </ContentControl>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</Window>
