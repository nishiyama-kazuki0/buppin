<Application x:Class="ExpressionDBCycleProcessApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ExpressionDBCycleProcessApp"
             xmlns:v="clr-namespace:ExpressionDBCycleProcessApp.Views"
             >
    <Application.Resources>
            <DataTemplate x:Key="UcMainTemplate">
                <v:UcMain />
            </DataTemplate>
            <DataTemplate x:Key="UcCommunicationAreaTemplate">
                <v:UcCommunicationArea />
            </DataTemplate>
            <DataTemplate x:Key="UcCommunicationArea2Template">
                <v:UcCommunicationArea2 />
            </DataTemplate>
            <DataTemplate x:Key="UcSequenceActionsTemplate">
                <v:UcSequenceActions />
            </DataTemplate>
            <DataTemplate x:Key="UcSequenceActions2Template">
                <v:UcSequenceActions2 />
            </DataTemplate>
            <DataTemplate x:Key="UcSequenceActionTreeTemplate">
                <v:UcSequenceActionTree />
            </DataTemplate>
            <DataTemplate x:Key="UcSequenceActionTree2Template">
                <v:UcSequenceActionTree2 />
            </DataTemplate>
            <DataTemplate x:Key="UcSequenceStepsTemplate">
                <v:UcSequenceSteps />
            </DataTemplate>
            <DataTemplate x:Key="UcSequenceStepHistoriesTemplate">
                <v:UcSequenceStepHistories />
            </DataTemplate>
            <DataTemplate x:Key="UcStartSequenceTemplate">
                <v:UcStartSequence />
            </DataTemplate>

        <!-- TextBoxのテキストをコピー貼付けできるLabel風にする -->
        <Style TargetType="TextBox" x:Key="LabelLikeStyle">
            <EventSetter Event="PreviewMouseDoubleClick" Handler="TextBox_PreviewMouseDoubleClick"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
    </Application.Resources>
</Application>
